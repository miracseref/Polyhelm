<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Terminal jump and prompt sending drive iTerm2 / Terminal.app over Apple
       events. Under the hardened runtime (required for notarization) this has to
       be declared, or those calls fail silently in a signed build. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
